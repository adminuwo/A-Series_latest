                subtitle: "ติดต่อเราสำหรับคำถามหรือการสนับสนุนใดๆ",
                form: {
                    name: "ชื่อเต็ม",
                    email: "ที่อยู่อีเมล",
                    subject: "หัวข้อ",
                    message: "ข้อความ",
                    send: "ส่งข้อความ",
                    sending: "กำลังส่ง...",
                },
